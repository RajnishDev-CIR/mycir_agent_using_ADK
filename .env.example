# ── Google AI ─────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-gemini-api-key

# ── PostgreSQL (matches docker-compose.yml) ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mycir
POSTGRES_USER=mycir_user
POSTGRES_PASSWORD=change-me-before-use

# ── pgAdmin (web UI at http://localhost:5050) ─────────────────────────────────
PGADMIN_EMAIL=admin@mycir.local
PGADMIN_PASSWORD=change-me-before-use

# ── MyCIR Agent behaviour ─────────────────────────────────────────────────────
# auto  → benchmark runs silently after every V2 estimate
# manual → only when user explicitly asks to compare
BENCHMARK_MODE=auto
